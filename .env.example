# Saldo pemain di-cache di localStorage key `pusattogel-player-balance` (diisi saat login /
# GET /profile / GET /balance; dihapus saat logout). Bukan sumber kebenaran — server selalu diutamakan.

# Aset publik (banner, logo path dari API, dll.): base URL absolut tanpa trailing slash.
# Kosong = pakai window.location.origin (dev/prod same host).
# VITE_PUBLIC_ASSET_BASE_URL=https://cdn.example.com

# Base URL REST API (tanpa trailing slash). Wajib prefix VITE_ agar terbaca di Vite.
# Kosong = fallback http://localhost:4010/api/v1 (mock-server lokal di repo).
# Produksi: set ke origin API Anda, mis. https://api.situs.com/api/v1
# VITE_API_BASE_URL=http://localhost:4010/api/v1
# VITE_API_BASE_URL=http://localhost:8080/api/v1
