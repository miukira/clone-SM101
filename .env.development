# npm run dev — API lewat proxy Vite (same-origin /api/v1 → staging), tanpa error CORS di browser.
# Jangan set VITE_API_BASE_URL ke URL absolut staging kecuali server sudah mengirim Access-Control-Allow-Origin.
VITE_API_PROXY_TARGET=https://staging.rdd-server.com
VITE_WEBSITE_DOMAIN=staging.rdd-server.com

# Opsional: fetch langsung ke staging (butuh CORS di backend):
# VITE_API_BASE_URL=https://staging.rdd-server.com/api/v1
