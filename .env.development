# Staging: request ke /api/v1 = same-origin, Vite proxy → https://staging.rdd-server.com (hindari CORS).
# JANGAN VITE_API_BASE_URL=https://staging... di dev — browser memblokir (No Access-Control-Allow-Origin).
VITE_API_BASE_URL=/api/v1
VITE_API_PROXY_TARGET=https://staging.rdd-server.com
# Multi-domain FE/SEO: default pakai hostname browser (window.location.hostname).
# Set hanya jika ingin override tenant saat dev lokal (contoh localhost):
# VITE_WEBSITE_DOMAIN=staging.rdd-server.com
#
# Langsung ke host API (bukan lewat Vite) — hanya bila server mengizinkan CORS ke http://localhost:5173
# VITE_API_BASE_URL=https://staging.rdd-server.com/api/v1
#
